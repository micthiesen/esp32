[
	{
		"label": "Build (Debug)",
		"command": "cargo build",
		"cwd": "$ZED_WORKTREE_ROOT",
		"reveal": "always",
		"hide": "on_success",
		"tags": ["build", "rust", "esp32"]
	},
	{
		"label": "Build (Release)",
		"command": "cargo build --release",
		"cwd": "$ZED_WORKTREE_ROOT",
		"reveal": "always",
		"hide": "on_success",
		"tags": ["build", "rust", "esp32"]
	},
	{
		"label": "Clean Build",
		"command": "cargo clean && cargo build",
		"cwd": "$ZED_WORKTREE_ROOT",
		"reveal": "always",
		"hide": "on_success",
		"tags": ["build", "rust", "esp32"]
	},
	{
		"label": "Flash & Monitor",
		"command": "cargo run",
		"cwd": "$ZED_WORKTREE_ROOT",
		"reveal": "always",
		"hide": "never",
		"tags": ["flash", "monitor", "rust", "esp32"]
	},
	{
		"label": "Flash Only",
		"command": "espflash flash target/riscv32imc-unknown-none-elf/release/battery-tester",
		"cwd": "$ZED_WORKTREE_ROOT",
		"reveal": "always",
		"hide": "on_success",
		"tags": ["flash", "rust", "esp32"]
	},
	{
		"label": "Monitor Only",
		"command": "espflash monitor",
		"cwd": "$ZED_WORKTREE_ROOT",
		"reveal": "always",
		"hide": "never",
		"tags": ["monitor", "rust", "esp32"]
	},
	{
		"label": "List Ports",
		"command": "espflash board-info",
		"cwd": "$ZED_WORKTREE_ROOT",
		"reveal": "always",
		"hide": "on_success",
		"tags": ["device", "esp32"]
	},
	{
		"label": "Device Info",
		"command": "espflash board-info",
		"cwd": "$ZED_WORKTREE_ROOT",
		"reveal": "always",
		"hide": "on_success",
		"tags": ["device", "esp32"]
	},
	{
		"label": "Erase Flash",
		"command": "espflash erase-flash",
		"cwd": "$ZED_WORKTREE_ROOT",
		"reveal": "always",
		"hide": "on_success",
		"tags": ["device", "esp32"]
	},
	{
		"label": "Check",
		"command": "cargo check",
		"cwd": "$ZED_WORKTREE_ROOT",
		"reveal": "always",
		"hide": "on_success",
		"tags": ["check", "rust"]
	},
	{
		"label": "Format",
		"command": "cargo fmt",
		"cwd": "$ZED_WORKTREE_ROOT",
		"reveal": "always",
		"hide": "on_success",
		"tags": ["format", "rust"]
	},
	{
		"label": "Clippy",
		"command": "cargo clippy",
		"cwd": "$ZED_WORKTREE_ROOT",
		"reveal": "always",
		"hide": "on_success",
		"tags": ["lint", "rust"]
	},
	{
		"label": "Flash (Release)",
		"command": "cargo run --release",
		"cwd": "$ZED_WORKTREE_ROOT",
		"reveal": "always",
		"hide": "never",
		"tags": ["flash", "monitor", "release", "rust", "esp32"]
	},
	{
		"label": "Save Firmware Image",
		"command": "espflash save-image --chip esp32c3 target/riscv32imc-unknown-none-elf/release/battery-tester battery-tester-firmware.bin",
		"cwd": "$ZED_WORKTREE_ROOT",
		"reveal": "always",
		"hide": "on_success",
		"tags": ["build", "esp32"]
	},
	{
		"label": "Claude Code",
		"command": "claude --dangerously-skip-permissions",
		"cwd": "$ZED_WORKTREE_ROOT",
		"use_new_terminal": true,
		"allow_concurrent_runs": true,
		"reveal": "always",
		"hide": "never",
		"show_summary": false,
		"show_command": false,
		"tags": ["ai", "assistant", "claude"]
	}
]
